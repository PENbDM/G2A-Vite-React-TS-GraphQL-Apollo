// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id           String   @id @default(uuid())
  title        String
  description  String?
  price        Float    // This will be your final/discounted price
  oldPrice     Float?   // Optional: To show the crossed-out original price
  discount     Int?     @default(0) // The percentage (e.g., 44 for -44%)
  isBestSeller Boolean  @default(false)
  imgUrl       String?

  // New Fields
  platform     Platform
  region       Region
  edition      Edition
  type         GameType

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orderItems   OrderItem[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  orders    Order[]
}

model Order {
  id String @id @default(uuid())
  userId String
  total Float
  status OrderStatus @default(PENDING)

  user User @relation(fields: [userId],references: [id])
  items OrderItem[]

  createdAt    DateTime @default(now())
}

model OrderItem {
  id        String  @id @default(uuid())

  orderId   String
  gameId    String

  price     Float   // price at time of purchase
  amount  Int

  order     Order   @relation(fields: [orderId], references: [id])
  game      Game    @relation(fields: [gameId], references: [id])
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

enum Platform {
  Steam
  Pc
  Ps5
  Xbox
}

enum Region {
  Global
  Europe
  Usa
}

enum Edition {
  Standard
  Deluxe
  Collection
}

enum GameType {
  Key
  Account
}

